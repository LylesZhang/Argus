GEMINI_API_KEY=your_key_here
PORT=3000
# Maximum total time for one analyze, focus, or label request (milliseconds).
GEMINI_REQUEST_TIMEOUT_MS=120000

# Supabase project settings. The service-role key stays on the server and is
# used only for account deletion; never copy it into the extension config.
SUPABASE_URL=https://your-project.supabase.co
# Use the project's publishable key (sb_publishable_...). Legacy anon keys also work.
SUPABASE_ANON_KEY=your_anon_key
# Server only. Use a secret key (sb_secret_...). Legacy service_role keys also work.
SUPABASE_SECRET_KEY=your_secret_key
