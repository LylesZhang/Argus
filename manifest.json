{
  "manifest_version": 3,
  "name": "Argus: Dyslexia and ADHD Reading Aid",
  "version": "0.4.1",
  "description": "AI-powered reading aid for people with dyslexia. Customizes any webpage with visual aids for better reading experience.",

  "permissions": [
    "storage",
    "sidePanel",
    "tabs"
  ],

  "host_permissions": [
    "https://argus-1ygn.onrender.com/*",
    "https://*.supabase.co/*"
  ],

  "optional_host_permissions": ["http://*/*", "https://*/*"],

  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },

  "externally_connectable": {
    "matches": ["https://argus-1ygn.onrender.com/auth/callback*"]
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/bundle.js"],
      "css": ["shared/mode-pill.css", "shared/panel-size.css", "content/content.css"],
      "run_at": "document_idle"
    }
  ],

  "side_panel": {
    "default_path": "panel/panel.html"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Argus"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [{
    "resources": ["fonts/*.otf", "pdf/pdf.worker.mjs"],
    "matches": ["http://*/*", "https://*/*"]
  }]
}
